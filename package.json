{
  "name": "ems-patient-care-reporting-system",
  "productName": "EMS Patient Care Reporting System",
  "version": "1.0.1",
  "description": "EMS Patient Care Reporting System desktop app built with Electron, React, and Django",
  "main": "electron/main.js",
  "author": "Rubin",
  "license": "MIT",
  "scripts": {
    "frontend:start": "npm start --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "electron": "electron .",
    "electron:start": "electron .",
    "backend:build": ".\\venv\\Scripts\\python.exe -m PyInstaller ems_backend.spec --noconfirm --clean --distpath dist --workpath build/backend",
    "dist": "npm run frontend:build && npm run backend:build && electron-builder",
    "dist:win": "npm run frontend:build && npm run backend:build && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ems.patientcare",
    "productName": "EMS Patient Care Reporting System",
    "directories": {
      "output": "release"
    },
    "files": [
      "frontend/build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/ems_backend.exe",
        "to": "backend/ems_backend.exe"
      },
      {
        "from": "db.sqlite3",
        "to": "seed/db.sqlite3"
      },
      {
        "from": "media",
        "to": "seed/media",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.ico",
      "executableName": "EMS Patient Care Reporting System",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EMS Patient Care Reporting System"
    }
  }
}